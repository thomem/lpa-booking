generator client {
  provider      = "prisma-client-js"
  // native = Windows (build local) ; rhel = runtime Netlify/AWS Lambda (Linux).
  // Les deux variantes OpenSSL couvrent Node 18 (AL2/1.0.x) et Node 20 (AL2023/3.0.x).
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  role          Role      @default(GUEST)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reservations  Booking[]
  reviews       Review[]
}

model Booking {
  id              String        @id @default(cuid())
  userId          String?
  user            User?         @relation(fields: [userId], references: [id])
  guestName       String
  guestEmail      String
  guestPhone      String?
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  nights          Int
  basePrice       Float
  cleaningFee     Float
  taxes           Float
  discount        Float         @default(0)
  totalPrice      Float
  status          BookingStatus @default(PENDING)
  stripeSessionId String?       @unique
  stripePaymentId String?
  promoCode       String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime @unique
  reason    String?
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  rating    Int
  comment   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PricingConfig {
  id              String   @id @default(cuid())
  basePrice       Float
  cleaningFee     Float
  taxRate         Float    @default(0.1)
  weeklyDiscount  Float    @default(0.1)
  monthlyDiscount Float    @default(0.2)
  minNights       Int      @default(1)
  maxGuests       Int      @default(8)
  updatedAt       DateTime @updatedAt
}

model PromoCode {
  id          String   @id @default(cuid())
  code        String   @unique
  discount    Float
  type        PromoType
  maxUses     Int?
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

enum Role {
  GUEST
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum PromoType {
  PERCENTAGE
  FIXED
}
